generator client {
  provider     = "prisma-client"
  output       = "../src/generated/prisma"
  moduleFormat = "cjs"
}

datasource db {
  provider = "postgresql"
}

model sensor_location {
  id        Int       @id @default(autoincrement())
  pais      String?   @db.VarChar(100)
  provincia String?   @db.VarChar(100)
  cidade    String?   @db.VarChar(100)
  latitude  Float?
  longitude Float?
  sensors   sensors[]
}

model sensor_readings {
  id          BigInt    @id @default(autoincrement())
  sensor_id   Int
  created_at  DateTime? @default(now()) @db.Timestamp(6)
  temperature Float?    @db.Real
  humidity    Float?    @db.Real
  pressure    Float?    @db.Real
  air_quality Float?    @db.Real
  sensors     sensors   @relation(fields: [sensor_id], references: [id], onDelete: Cascade, onUpdate: NoAction, map: "fk_reading_sensor")

  @@index([sensor_id, created_at(sort: Desc)], map: "idx_sensor_readings_sensor_time")
}

model sensors {
  id                 Int                  @id @default(autoincrement())
  sensor_code        String               @unique @db.VarChar(50)
  created_at         DateTime?            @default(now()) @db.Timestamp(6)
  id_location        Int
  sensor_readings    sensor_readings[]
  sensor_location    sensor_location      @relation(fields: [id_location], references: [id], onDelete: Cascade, onUpdate: NoAction, map: "fk_location_sensor")
  sensors_allocation sensors_allocation[]
}

model sensors_allocation {
  id         Int       @id @default(autoincrement())
  sensor_id  Int
  id_usuario Int
  created_at DateTime? @default(now()) @db.Timestamp(6)
  sensors    sensors   @relation(fields: [sensor_id], references: [id], onDelete: Cascade, onUpdate: NoAction, map: "fk_alloc_sensor")
  usuario    usuario   @relation(fields: [id_usuario], references: [id], onDelete: Cascade, onUpdate: NoAction, map: "fk_alloc_usuario")

  @@unique([sensor_id, id_usuario], map: "unique_sensor_usuario")
}

model tokens {
  id            Int       @id @default(autoincrement())
  id_usuario    Int
  refresh_token String
  created_at    DateTime? @default(now()) @db.Timestamp(6)
  usuario       usuario   @relation(fields: [id_usuario], references: [id], onDelete: Cascade, onUpdate: NoAction, map: "fk_token_usuario")
}

model usuario {
  id                 Int                  @id @default(autoincrement())
  nome               String               @db.VarChar(100)
  role               String               @db.VarChar(40)
  email              String               @unique @db.VarChar(150)
  senha              String               @db.VarChar(1000)
  telefone           String?              @db.VarChar(15)
  created_at         DateTime?            @default(now()) @db.Timestamp(6)
  sensors_allocation sensors_allocation[]
  tokens             tokens[]
}
